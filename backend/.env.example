# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=oceano
DB_PORT=3306

# Server Configuration
PORT=5000
NODE_ENV=development

# Security (Add these for future JWT implementation)
